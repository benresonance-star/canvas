{
  "name": "canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:sync": "node --max-old-space-size=8192 ./node_modules/vitest/vitest.mjs run projectPatch projectSync placement projectDocument actionSync schemas syncProjectionInvariants projectSwitch projects canvasProjects canvas-projects.postgres projectDocumentStore workspaceIntegrity specDataPlane spec-canvas-state useSyncStreams useWorkspaceIndexSync workspaceIndexSyncStream",
    "test:features": "vitest run src/features",
    "test:e2e": "node scripts/placement-switch-e2e.mjs",
    "baseline": "node scripts/capture-architecture-baseline.mjs",
    "server": "node --use-system-ca server/index.js",
    "db:migrate": "node server/migrate.js",
    "db:up": "docker compose -f ../docker-compose.yml up -d"
  },
  "dependencies": {
    "@extend-ai/react-xlsx": "^0.11.0",
    "@xyflow/react": "^12.11.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "js-tiktoken": "^1.0.20",
    "jsmediatags": "^3.9.7",
    "lucide-react": "^0.513.0",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.49.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
