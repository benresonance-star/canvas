# Copy to .env and adjust for your machine (optional — defaults work for local Docker stack).
# Used by: npm run server, npm run dev:stack

DATABASE_URL=postgresql://canvas:canvas@localhost:5432/canvas
PORT=3001

# Vite dev proxy target (must match PORT above; dev:stack sets this automatically)
# VITE_API_PROXY_TARGET=http://localhost:3001

# Local Ollama (docker container canvas-ollama or native install)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: encrypt stored agent API keys (generate a random 32+ char string)
# AGENT_SECRETS_KEY=
